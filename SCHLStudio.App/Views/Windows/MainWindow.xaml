<Window x:Class="SCHLStudio.App.Views.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:nav="clr-namespace:SCHLStudio.App.Views.Shell"
        xmlns:dash="clr-namespace:SCHLStudio.App.Views.Dashboard"
        xmlns:expl2="clr-namespace:SCHLStudio.App.Views.ExplorerV2"
        xmlns:live="clr-namespace:SCHLStudio.App.Views.LiveTracking"
        xmlns:search="clr-namespace:SCHLStudio.App.Views.Search"
        xmlns:settings="clr-namespace:SCHLStudio.App.Views.Settings"
        Title="SCHL App - AUTO TRACKING"
        Height="820"
        Width="1500"
        MinHeight="600"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal"
        Background="{StaticResource BgMainBrush}"
        Icon="/app_icon.ico">

    <Window.Resources>
        <Style x:Key="ShellNavListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style x:Key="ShellNavItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="6,6"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="FontFamily" Value="{StaticResource MainFontFamily}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="HeaderBorder"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="{StaticResource BgCardHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="{StaticResource BgCardBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ShellTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="FontFamily" Value="{StaticResource MainFontFamily}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="HeaderBorder"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}"
                                Margin="6,6,0,6">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="{StaticResource BgCardHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="{StaticResource BgCardBrush}"/>
                                <Setter TargetName="HeaderBorder" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                <Setter TargetName="HeaderBorder" Property="BorderThickness" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HiddenShellTabItemStyle" TargetType="TabItem" BasedOn="{StaticResource ShellTabItemStyle}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>

        <Style x:Key="ShellTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BgCardHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LogoutOutlineButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="{StaticResource MainFontFamily}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="{StaticResource BgCardHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="{StaticResource BgCardBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid>
        <TabControl x:Name="MainTabs"
                    Style="{StaticResource ShellTabControlStyle}"
                    ItemContainerStyle="{StaticResource ShellTabItemStyle}"
                    SelectedIndex="0">
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <DockPanel LastChildFill="True">
                        <Grid DockPanel.Dock="Top">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TabPanel Grid.Column="0"
                                      IsItemsHost="True"
                                      Margin="0" />

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="6,6,10,6">
                                <Border Background="{StaticResource BgCardBrush}"
                                        BorderBrush="{StaticResource BorderLightBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="14,8"
                                        Margin="0,0,16,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DataContext.CurrentDisplayName, RelativeSource={RelativeSource AncestorType=Window}}"
                                               Foreground="{StaticResource TextMainBrush}"
                                               FontFamily="{StaticResource MainFontFamily}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </Border>

                                <Button Content="Logout"
                                        Style="{StaticResource LogoutOutlineButtonStyle}"
                                        VerticalAlignment="Center"
                                        Click="LogoutButton_Click" />
                            </StackPanel>
                        </Grid>

                        <ContentPresenter ContentSource="SelectedContent"
                                          Margin="0" />
                    </DockPanel>
                </ControlTemplate>
            </TabControl.Template>
            <TabItem x:Name="FilesTab" Header="Files">
                <expl2:ExplorerV2View x:Name="ExplorerV2" />
            </TabItem>

            <TabItem x:Name="DashboardTab" Header="Dashboard">
                <dash:DashboardView Username="{Binding DataContext.CurrentUser, RelativeSource={RelativeSource AncestorType=Window}}" />
            </TabItem>

            <TabItem x:Name="SearchTab" Header="Search">
                <search:SearchView />
            </TabItem>

            <TabItem x:Name="LiveTrackingTab" Header="Live Tracking">
                <live:LiveTrackingView />
            </TabItem>

            <TabItem x:Name="SettingsTab" Header="Settings">
                <settings:SettingsView />
            </TabItem>
        </TabControl>
    </Grid>
</Window>
