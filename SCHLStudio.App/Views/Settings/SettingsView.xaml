<UserControl x:Class="SCHLStudio.App.Views.Settings.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{DynamicResource BgMainBrush}" Margin="20">
        <Border Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1" CornerRadius="12" Padding="18">
            <StackPanel>
                <TextBlock Text="Settings" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextMainBrush}" Margin="0,0,0,12" />
                <TextBlock Text="Settings page" Foreground="{DynamicResource TextSecondaryBrush}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
