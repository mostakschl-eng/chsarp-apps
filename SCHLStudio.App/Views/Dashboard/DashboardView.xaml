<UserControl x:Class="SCHLStudio.App.Views.Dashboard.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dash="clr-namespace:SCHLStudio.App.Views.Dashboard"
             xmlns:tabs="clr-namespace:SCHLStudio.App.Views.LiveTracking.Tabs"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="{DynamicResource BgMainBrush}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/SCHLStudio.App;component/Views/LiveTracking/Shared/LiveTrackingStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="LiveTrackingTabItemStyle" TargetType="TabItem">
                <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}" />
                <Setter Property="FontFamily" Value="{StaticResource MainFontFamily}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Padding" Value="16,9" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Border x:Name="HeaderBorder"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="{TemplateBinding Padding}"
                                    Margin="0,0,8,0">
                                <ContentPresenter ContentSource="Header"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="HeaderBorder" Property="Background" Value="{DynamicResource BgCardHoverBrush}" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="HeaderBorder" Property="Background" Value="{DynamicResource BgCardBrush}" />
                                    <Setter TargetName="HeaderBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="LiveTrackingTabControlStyle" TargetType="TabControl">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="0" />
            </Style>

            <Style x:Key="DashboardTabItemStyle" TargetType="TabItem" BasedOn="{StaticResource LiveTrackingTabItemStyle}" />
            <Style x:Key="DashboardTabControlStyle" TargetType="TabControl" BasedOn="{StaticResource LiveTrackingTabControlStyle}" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BgMainBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="24,20,24,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="10" Height="10" Fill="#34C759" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock Text="DASHBOARD"
                           Foreground="{DynamicResource TextMainBrush}"
                           FontFamily="{StaticResource MainFontFamily}"
                           FontSize="18" FontWeight="Bold"
                           VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Filter icon button (matches Live Tracking style) -->
                <ToggleButton x:Name="DashFilterToggle" Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center" Margin="0,0,10,0">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="Bd" Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="1" CornerRadius="8" Padding="6,5" Cursor="Hand">
                                <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                    <Setter TargetName="Bd" Property="Background" Value="#E8F0FE"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#F0F4FF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>

                <!-- Filter Popup -->
                <Popup IsOpen="{Binding IsChecked, ElementName=DashFilterToggle}" StaysOpen="False" Placement="Bottom" PlacementTarget="{Binding ElementName=DashFilterToggle}" HorizontalOffset="-180" VerticalOffset="4" AllowsTransparency="True">
                    <Border Background="White" CornerRadius="10" BorderBrush="#E0E0E5" BorderThickness="1" Padding="14" MinWidth="240">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" Opacity="0.15" ShadowDepth="4" Direction="270"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="Date Filter" FontFamily="{StaticResource MainFontFamily}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextMainBrush}" Margin="0,0,0,10"/>

                            <TextBlock Text="DATE" FontFamily="{StaticResource MainFontFamily}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <DatePicker SelectedDate="{Binding SelectedDate, Mode=TwoWay}" Width="200" Height="30" FontFamily="{StaticResource MainFontFamily}" FontSize="12" Margin="0,0,0,12"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Today" Background="Transparent" Foreground="{DynamicResource TextSecondaryBrush}" BorderThickness="0" FontSize="11" FontFamily="{StaticResource MainFontFamily}" Padding="8,4" Cursor="Hand" Margin="0,0,6,0"
                                        Click="DashFilterToday_Click"/>
                                <Button Content="Apply" Style="{StaticResource PrimaryButtonStyle}" MinWidth="60" Height="28" FontSize="11" FontFamily="{StaticResource MainFontFamily}" Padding="10,2" Cursor="Hand"
                                        Click="DashFilterApply_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Popup>

                <Button Width="28"
                        Height="28"
                        Padding="0"
                        Background="Transparent"
                        Foreground="{DynamicResource TextMainBrush}"
                        BorderThickness="0"
                        Margin="0,0,10,0"
                        Command="{Binding ReloadCommand}"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                        Cursor="Hand"
                        RenderTransformOrigin="0.5,0.5"
                        ToolTip="Reload">
                    <Button.RenderTransform>
                        <RotateTransform Angle="0" />
                    </Button.RenderTransform>
                    <Button.Resources>
                        <Storyboard x:Key="ReloadSpin">
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                             From="0" To="360" Duration="0:0:0.35" />
                        </Storyboard>
                    </Button.Resources>
                    <Button.Triggers>
                        <EventTrigger RoutedEvent="Button.Click">
                            <BeginStoryboard Storyboard="{StaticResource ReloadSpin}" />
                        </EventTrigger>
                    </Button.Triggers>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="0">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="&#xE72C;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="16"
                               Foreground="{DynamicResource TextMainBrush}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center" />
                </Button>

                <Border Background="{DynamicResource BgCardBrush}"
                        BorderBrush="{DynamicResource BorderLightBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="10,6"
                        Height="32"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" />
                </Border>
            </StackPanel>
        </Grid>

        <TabControl Grid.Row="1"
                    Margin="24,10,24,20"
                    Style="{StaticResource DashboardTabControlStyle}"
                    ItemContainerStyle="{StaticResource DashboardTabItemStyle}">
            <TabControl.Resources>
                <Style TargetType="TabPanel">
                    <Setter Property="Margin" Value="0,0,0,20" />
                </Style>
            </TabControl.Resources>

            <TabItem Header="PRODUCTION">
                <tabs:ProductionTabView />
            </TabItem>
            <TabItem Header="ACTIVITY">
                <dash:DashboardActivityTabView />
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
