<Application x:Class="SCHLStudio.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SCHLStudio.App.Converters"
             >
    <Application.Resources>
         <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Shared/Resources/Themes/Theme.Light.xaml"/>
                <ResourceDictionary Source="Views/Styles/Colors.xaml"/>
                <ResourceDictionary Source="Views/Styles/Buttons.xaml"/>
                <ResourceDictionary Source="Views/Styles/TextBlocks.xaml"/>
                <ResourceDictionary Source="Views/Styles/Icons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Value Converters -->
            <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <local:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <local:RadioButtonConverter x:Key="RadioButtonConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
