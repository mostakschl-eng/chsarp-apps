<Window x:Class="SCHLStudio.App.Views.Login.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SCHL App - LOGIN" 
        Height="520" 
        Width="380"
        MinHeight="520"
        MinWidth="380"
        MaxHeight="520"
        MaxWidth="380"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgMainBrush}"
        ResizeMode="CanMinimize"
        Icon="/app_icon.ico">

    <Window.Resources>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource BgCardBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BgCardHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BackIconButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <!-- Main Container -->
        <Border Background="{DynamicResource BgMainBrush}" Padding="25">
            <!-- Content Card -->
            <Border Background="{DynamicResource BgCardBrush}" 
                    CornerRadius="12">
                
                <Grid>
                    <!-- Step 1: Username -->
                    <Grid Visibility="{Binding IsUsernameStep, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Welcome Header -->
                        <StackPanel Grid.Row="1" Margin="20,0,20,8">
                            <TextBlock Text="{Binding Greeting}" 
                                      FontSize="26" 
                                      FontWeight="Bold"
                                      Foreground="{StaticResource TextMainBrush}"
                                      Margin="0,0,0,4"/>
                            <TextBlock Text="SCHL App" 
                                      FontSize="14"
                                      Foreground="{StaticResource PrimaryBrush}"
                                      Margin="0,0,0,4"/>
                            <TextBlock Text="Track your Photoshop work seamlessly" 
                                      FontSize="12"
                                      Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        
                        <!-- Username Input -->
                        <StackPanel Grid.Row="2" Margin="20,20,20,10">
                            <TextBlock Text="Username" 
                                      Style="{StaticResource ModernLabelStyle}"/>
                            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                    Style="{StaticResource ModernTextBoxStyle}"
                                    Height="42">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding CheckUsernameCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                        </StackPanel>
                        
                        <!-- Next Button -->
                        <Button Grid.Row="3" 
                               Command="{Binding CheckUsernameCommand}"
                               Height="46"
                               Margin="20,12,20,0"
                               IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                    <Setter Property="Content" Value="Next"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                            <Setter Property="Content" Value="{Binding StatusMessage}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                    
                    <!-- Step 2a: Password (if user has password) -->
                    <Grid Visibility="{Binding IsPasswordStep, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Welcome with Username -->
                        <StackPanel Grid.Row="0" Margin="20,30,20,20">
                            <TextBlock FontSize="20" 
                                      FontWeight="Bold"
                                      Foreground="{StaticResource TextMainBrush}"
                                      Margin="0,0,0,4">
                                <Run Text="{Binding Greeting}"/><Run Text=", "/><Run Text="{Binding Username}"/><Run Text="!"/>
                            </TextBlock>
                            <TextBlock Text="Enter your password to continue" 
                                      FontSize="12"
                                      Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        
                        <!-- Password Input -->
                        <StackPanel Grid.Row="1" Margin="20,10,20,10">
                            <TextBlock Text="Password" 
                                      Style="{StaticResource ModernLabelStyle}"/>
                            <PasswordBox x:Name="PasswordInput"
                                        Style="{StaticResource ModernPasswordBoxStyle}"
                                        Height="42">
                                <PasswordBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding LoginCommand}"/>
                                </PasswordBox.InputBindings>
                            </PasswordBox>
                        </StackPanel>

                        <!-- Login Button -->
                        <Button Grid.Row="2" 
                               Command="{Binding LoginCommand}"
                               Height="46"
                               Margin="20,0,20,10"
                               IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                    <Setter Property="Content" Value="Login"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                            <Setter Property="Content" Value="{Binding StatusMessage}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Grid.Row="4"
                                Content="←"
                                Command="{Binding BackToUsernameCommand}"
                                Margin="20,0,0,20"
                                VerticalAlignment="Bottom"
                                HorizontalAlignment="Left"
                                Style="{StaticResource BackIconButtonStyle}"/>
                    </Grid>
                    
                    <!-- Step 2b: Set Password (if user has no password) -->
                    <Grid Visibility="{Binding IsSetPasswordStep, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Welcome Message -->
                        <StackPanel Grid.Row="0" Margin="20,30,20,10">
                            <TextBlock Text="Welcome!" 
                                      FontSize="16" 
                                      FontWeight="Bold"
                                      Foreground="{StaticResource TextMainBrush}"
                                      Margin="0,0,0,4"/>
                            <TextBlock FontSize="13"
                                      Foreground="{StaticResource TextSecondaryBrush}">
                                <Run Text="Please create a password for "/><Run Text="{Binding Username}"/>
                            </TextBlock>
                        </StackPanel>
                        
                        <!-- New Password -->
                        <StackPanel Grid.Row="1" Margin="20,10,20,10">
                            <TextBlock Text="New Password" 
                                      Style="{StaticResource ModernLabelStyle}"/>
                            <PasswordBox x:Name="NewPasswordInput"
                                        Style="{StaticResource ModernPasswordBoxStyle}"
                                        Height="42">
                                <PasswordBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding CreatePasswordCommand}"/>
                                </PasswordBox.InputBindings>
                            </PasswordBox>
                        </StackPanel>
                        
                        <!-- Confirm Password -->
                        <StackPanel Grid.Row="2" Margin="20,0,20,15">
                            <TextBlock Text="Confirm Password" 
                                      Style="{StaticResource ModernLabelStyle}"/>
                            <PasswordBox x:Name="ConfirmPasswordInput"
                                        Style="{StaticResource ModernPasswordBoxStyle}"
                                        Height="42">
                                <PasswordBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding CreatePasswordCommand}"/>
                                </PasswordBox.InputBindings>
                            </PasswordBox>
                        </StackPanel>

                        <!-- Create Password Button -->
                        <Button Grid.Row="3" 
                               Command="{Binding CreatePasswordCommand}"
                               Height="46"
                               Margin="20,0,20,10"
                               IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                    <Setter Property="Content" Value="Create Password"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                            <Setter Property="Content" Value="{Binding StatusMessage}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Grid.Row="4"
                                Content="←"
                                Command="{Binding BackToUsernameCommand}"
                                Margin="20,0,0,20"
                                VerticalAlignment="Bottom"
                                HorizontalAlignment="Left"
                                Style="{StaticResource BackIconButtonStyle}"/>
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>
