<UserControl x:Class="SCHLStudio.App.Views.Shell.Sidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="SidebarNavListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style x:Key="SidebarNavItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="FontFamily" Value="{StaticResource MainFontFamily}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="11"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Border x:Name="SelectBar"
                                        Width="3"
                                        CornerRadius="2"
                                        Background="Transparent"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Stretch"/>
                                <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource BgCardHoverBrush}"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource DividerBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource BgCardBrush}"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource DividerBrush}"/>
                                <Setter TargetName="SelectBar" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Width="220" Background="{StaticResource BgMainBrush}" BorderThickness="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="SCHL"
                       Foreground="{StaticResource TextMainBrush}"
                       FontWeight="Bold"
                       FontSize="14"
                       Margin="18,14,18,6"/>

            <ListBox Grid.Row="1"
                     x:Name="NavList"
                     Style="{StaticResource SidebarNavListBoxStyle}"
                     ItemContainerStyle="{StaticResource SidebarNavItemStyle}"
                     SelectedIndex="{Binding SelectedIndex, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}">
                <ListBoxItem Content="Files" />
                <ListBoxItem Content="Dashboard" />
                <ListBoxItem Content="Search" />
                <ListBoxItem Content="Live Tracking" />
                <ListBoxItem Content="Settings" />
            </ListBox>
        </Grid>
    </Border>
</UserControl>
