<Window x:Class="SCHLStudio.App.Views.Dialogs.ConfirmLogoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Logout"
        Height="220"
        Width="520"
        MinHeight="220"
        MaxHeight="220"
        MinWidth="520"
        MaxWidth="520"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="/app_icon.ico">

    <Border Padding="14" Background="{StaticResource BgMainBrush}" CornerRadius="14">
        <Border Background="{StaticResource BgCardBrush}" CornerRadius="12" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Logout"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextMainBrush}"
                           Margin="0,0,0,10" />

                <TextBlock Grid.Row="1"
                           Text="Are you sure you want to logout?"
                           FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12" />

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="1"
                            Content="Cancel"
                            Width="100"
                            Height="32"
                            Margin="0,0,10,0"
                            Click="Cancel_Click"
                            Foreground="{StaticResource TextMainBrush}"
                            Background="{StaticResource BgCardBrush}"
                            BorderBrush="{StaticResource PrimaryBrush}"
                            BorderThickness="1">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="10"
                                        Padding="10,6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Grid.Column="2"
                            Content="Logout"
                            Width="100"
                            Height="32"
                            Click="Confirm_Click"
                            Foreground="{StaticResource PrimaryBrush}"
                            Background="Transparent"
                            BorderBrush="{StaticResource PrimaryBrush}"
                            BorderThickness="1">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="BtnBorder"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="10"
                                        Padding="10,6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BtnBorder" Property="Background" Value="{StaticResource BgCardHoverBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="BtnBorder" Property="Background" Value="{StaticResource BgCardBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
