<Window x:Class="SCHLStudio.App.Views.Dialogs.CommentDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Report"
        Height="240"
        Width="560"
        MinHeight="240"
        MinWidth="560"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="/app_icon.ico">

    <Border Padding="24" Background="Transparent">
        <Border Background="{StaticResource BgCardBrush}" CornerRadius="16" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Direction="270" ShadowDepth="3" Opacity="0.15" Color="Black"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Report Details"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextMainBrush}" />

                    <Button Grid.Column="1"
                            Width="28"
                            Height="28"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Click="Cancel_Click"
                            Cursor="Hand">
                        <TextBlock Text="&#xE711;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center" />
                    </Button>
                </Grid>

                <Border Grid.Row="1" Background="{StaticResource BgMainBrush}" CornerRadius="10" BorderBrush="{StaticResource DividerBrush}" BorderThickness="1">
                    <TextBox x:Name="CommentInput"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             Background="Transparent"
                             Foreground="{StaticResource TextMainBrush}"
                             BorderThickness="0"
                             Padding="12,10"
                             FontSize="14" />
                </Border>

                <Grid Grid.Row="2" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="1"
                            Content="Cancel"
                            Width="110"
                            Height="36"
                            Margin="0,0,12,0"
                            Click="Cancel_Click"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextMainBrush}"
                            Background="{StaticResource BgCardBrush}"
                            BorderBrush="{StaticResource DividerBrush}"
                            BorderThickness="1"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="BtnBorder" Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8"
                                        Padding="10,6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BtnBorder" Property="Background" Value="{StaticResource HoverBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Grid.Column="2"
                            Content="Submit Report"
                            Width="120"
                            Height="36"
                            Click="Submit_Click"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Background="{StaticResource PrimaryBrush}"
                            BorderThickness="0"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="BtnBorder" Background="{TemplateBinding Background}"
                                        CornerRadius="8"
                                        Padding="10,6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BtnBorder" Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
