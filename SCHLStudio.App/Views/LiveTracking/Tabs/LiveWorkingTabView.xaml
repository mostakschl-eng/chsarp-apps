<UserControl x:Class="SCHLStudio.App.Views.LiveTracking.Tabs.LiveWorkingTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/SCHLStudio.App;component/Views/LiveTracking/Shared/LiveTrackingStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,8,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource LiveCardStyle}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="WORKING" Style="{StaticResource LiveCardLabelStyle}" />
                    <TextBlock Text="0" Style="{StaticResource LiveCardValueStyle}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource LiveCardStyle}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="PAUSE" Style="{StaticResource LiveCardLabelStyle}" />
                    <TextBlock Text="0" Style="{StaticResource LiveCardValueStyle}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource LiveCardStyle}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="WALK OUT" Style="{StaticResource LiveCardLabelStyle}" />
                    <TextBlock Text="0" Style="{StaticResource LiveCardValueStyle}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Style="{StaticResource LiveCardStyle}">
                <StackPanel>
                    <TextBlock Text="DONE" Style="{StaticResource LiveCardLabelStyle}" />
                    <TextBlock Text="0" Style="{StaticResource LiveCardValueStyle}" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="1" Background="{StaticResource BgCardBrush}" CornerRadius="10" Padding="12,10" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="CLIENT" Style="{StaticResource LiveGridHeaderTextStyle}" Margin="6,0,0,0" />
                <TextBlock Grid.Column="1" Text="WORKING" Style="{StaticResource LiveGridHeaderTextStyle}" HorizontalAlignment="Center" />
                <TextBlock Grid.Column="2" Text="PAUSE" Style="{StaticResource LiveGridHeaderTextStyle}" HorizontalAlignment="Center" />
                <TextBlock Grid.Column="3" Text="DONE" Style="{StaticResource LiveGridHeaderTextStyle}" HorizontalAlignment="Center" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="Transparent"
                Padding="10">
            <TextBlock Text="(No data yet)"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontFamily="{StaticResource MainFontFamily}"
                       FontSize="13" />
        </Border>
    </Grid>
</UserControl>
