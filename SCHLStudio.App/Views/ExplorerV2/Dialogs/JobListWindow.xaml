<Window x:Class="SCHLStudio.App.Views.ExplorerV2.JobListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Job List"
        Width="980"
        Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="38"
                            CornerRadius="12"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="0"
                            UseAeroCaptionButtons="True" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="JobListSearchTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Padding="{TemplateBinding Padding}" />
                                <TextBlock x:Name="WatermarkText"
                                           Text="{TemplateBinding Tag}"
                                           Margin="{TemplateBinding Padding}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Opacity="0.9"
                                           IsHitTestVisible="False"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="WatermarkText" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="JobListComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Margin" Value="0,3" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgCardHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource BgCardBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderLightBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource JobListComboBoxItemStyle}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          FocusVisualStyle="{x:Null}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <Border x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="26" />
                                        </Grid.ColumnDefinitions>

                                        <ContentPresenter Grid.Column="0"
                                                          Margin="{TemplateBinding Padding}"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Left"
                                                          Content="{TemplateBinding SelectionBoxItem}"
                                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                          ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}" />

                                        <TextBlock Grid.Column="1"
                                                   Text="&#xE70D;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Background="{DynamicResource BgCardBrush}"
                                        BorderBrush="{DynamicResource BorderLightBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="4"
                                        Margin="0,4,0,0">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgCardHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="90" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="{DynamicResource BgCardBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgCardHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                <Setter TargetName="Bd" Property="BorderThickness" Value="1" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RowToggleButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabelTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>

        <Style x:Key="FieldValueTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMainBrush}"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ResultsListStyle" TargetType="ListView">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="False"/>
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
        </Style>

        <Style x:Key="ResultsListItemStyle" TargetType="ListViewItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="RowBd"
                                Background="{DynamicResource BgCardBrush}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="12"
                                Margin="0,0,18,0"
                                Padding="14,12"
                                MinHeight="46"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowBd" Property="Background" Value="{DynamicResource BgCardHoverBrush}"/>
                                <Setter TargetName="RowBd" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RowBd" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                <Setter TargetName="RowBd" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsAdded}" Value="True">
                                <Setter TargetName="RowBd" Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
                            </DataTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RowBd" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource BgMainBrush}"
            BorderBrush="{DynamicResource PrimaryBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="16"
            UseLayoutRounding="True"
            MouseLeftButtonDown="WindowRoot_MouseLeftButtonDown">

        <Grid Grid.IsSharedSizeScope="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="Job List"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMainBrush}"
                               VerticalAlignment="Center" />

                    <TextBlock x:Name="CountsText"
                               Text=""
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="10,1,0,0"
                               VerticalAlignment="Center" />

                    <Button x:Name="ReloadButton"
                            Width="28"
                            Height="28"
                            Padding="0"
                            Background="Transparent"
                            Foreground="{DynamicResource TextMainBrush}"
                            BorderThickness="0"
                            Margin="10,0,0,0"
                            Click="ReloadButton_Click"
                            RenderTransformOrigin="0.5,0.5"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button.RenderTransform>
                            <RotateTransform Angle="0" />
                        </Button.RenderTransform>
                        <Button.Resources>
                            <Storyboard x:Key="ReloadSpin">
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                 From="0" To="360" Duration="0:0:0.35" />
                            </Storyboard>
                        </Button.Resources>
                        <Button.Triggers>
                            <EventTrigger RoutedEvent="Button.Click">
                                <BeginStoryboard Storyboard="{StaticResource ReloadSpin}" />
                            </EventTrigger>
                        </Button.Triggers>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent"
                                        BorderBrush="Transparent"
                                        BorderThickness="0">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="&#xE72C;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="16"
                                   Foreground="{DynamicResource TextMainBrush}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center" />
                    </Button>

                    <StackPanel Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                        <ToggleButton x:Name="RunningStatusButton"
                                      Content="RUNNING"
                                      Style="{StaticResource StatusToggleButtonStyle}"
                                      Click="RunningStatusButton_Click" />
                        <ToggleButton x:Name="QcStatusButton"
                                      Content="QC"
                                      Margin="8,0,0,0"
                                      Style="{StaticResource StatusToggleButtonStyle}"
                                      Click="QcStatusButton_Click" />
                        <ToggleButton x:Name="CorrectionStatusButton"
                                      Content="CORRECTION"
                                      Margin="8,0,0,0"
                                      Style="{StaticResource StatusToggleButtonStyle}"
                                      Click="CorrectionStatusButton_Click" />
                        <ToggleButton x:Name="TestStatusButton"
                                      Content="TEST"
                                      Margin="8,0,0,0"
                                      Style="{StaticResource StatusToggleButtonStyle}"
                                      Click="TestStatusButton_Click" />
                    </StackPanel>

                    <TextBox x:Name="SearchTextBox"
                             Width="240"
                             Height="28"
                             Margin="10,0,0,0"
                             Tag="Client Code Search"
                             Style="{StaticResource JobListSearchTextBoxStyle}"
                             TextChanged="SearchTextBox_TextChanged" />
                </StackPanel>

                <Button Grid.Column="1"
                        Content="✕"
                        Width="34"
                        Height="34"
                        Padding="0"
                        Background="Transparent"
                        Foreground="{DynamicResource TextMainBrush}"
                        BorderThickness="0"
                        Click="CloseButton_Click"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#11000000" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#22000000" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <Border Grid.Row="2"
                    Background="{DynamicResource BgCardBrush}"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    CornerRadius="12"
                    Padding="14,12"
                    Margin="0,0,18,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30" SharedSizeGroup="ActionCol" />
                        <ColumnDefinition Width="140" SharedSizeGroup="ClientCol" />
                        <ColumnDefinition Width="3*" MinWidth="240" SharedSizeGroup="FolderCol" />
                        <ColumnDefinition Width="1*" MinWidth="70" SharedSizeGroup="EtCol" />
                        <ColumnDefinition Width="1*" MinWidth="70" SharedSizeGroup="NofCol" />
                        <ColumnDefinition Width="2*" MinWidth="200" SharedSizeGroup="TaskCol" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="1" Text="CLIENT" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,10,0" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="FOLDER PATH" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,12,0" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="3" Text="ET" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,12,0" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="4" Text="NOF" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,12,0" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="5" Text="TASK" Style="{StaticResource FieldLabelTextStyle}" VerticalAlignment="Center" />

                    <Border Grid.Column="1" BorderBrush="#22000000" BorderThickness="0,0,1,0" Margin="0,0,12,0" VerticalAlignment="Stretch" SnapsToDevicePixels="True" />
                    <Border Grid.Column="2" BorderBrush="#22000000" BorderThickness="0,0,1,0" Margin="0,0,12,0" VerticalAlignment="Stretch" SnapsToDevicePixels="True" />
                    <Border Grid.Column="3" BorderBrush="#22000000" BorderThickness="0,0,1,0" Margin="0,0,12,0" VerticalAlignment="Stretch" SnapsToDevicePixels="True" />
                    <Border Grid.Column="4" BorderBrush="#22000000" BorderThickness="0,0,1,0" Margin="0,0,12,0" VerticalAlignment="Stretch" SnapsToDevicePixels="True" />
                </Grid>
            </Border>

            <ListView x:Name="JobsList"
                      Grid.Row="4"
                      Style="{StaticResource ResultsListStyle}"
                      ItemContainerStyle="{StaticResource ResultsListItemStyle}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid VerticalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30" SharedSizeGroup="ActionCol" />
                                <ColumnDefinition Width="140" SharedSizeGroup="ClientCol" />
                                <ColumnDefinition Width="3*" MinWidth="240" SharedSizeGroup="FolderCol" />
                                <ColumnDefinition Width="1*" MinWidth="70" SharedSizeGroup="EtCol" />
                                <ColumnDefinition Width="1*" MinWidth="70" SharedSizeGroup="NofCol" />
                                <ColumnDefinition Width="2*" MinWidth="200" SharedSizeGroup="TaskCol" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0" VerticalAlignment="Center">

                                <Button Style="{StaticResource RowToggleButtonStyle}"
                                        Click="ToggleRowButton_Click"
                                        Tag="{Binding}"
                                        VerticalAlignment="Center">
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               TextAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="&#xEA3A;" />
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAdded}" Value="True">
                                                        <Setter Property="Text" Value="&#xE73E;" />
                                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Button>
                            </Grid>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding ClientCode}"
                                       Style="{StaticResource FieldValueTextStyle}"
                                       Margin="0,0,12,0"
                                       Cursor="Hand"
                                       MouseLeftButtonDown="ClientCodeText_MouseLeftButtonDown" />
                            <Grid Grid.Column="2" Margin="0,0,12,0" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="26" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding FolderPathShort}"
                                           ToolTip="{Binding FolderPath}"
                                           ToolTipService.InitialShowDelay="0"
                                           Style="{StaticResource FieldValueTextStyle}"
                                           Cursor="Hand"
                                           MouseLeftButtonDown="FolderPathText_MouseLeftButtonDown" />

                                <Button Grid.Column="1"
                                        Width="26"
                                        Height="26"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Click="CopyFolderPathButton_Click"
                                        Tag="{Binding}"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="&#xE8C8;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="14"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center" />
                                </Button>
                            </Grid>

                            <TextBlock Grid.Column="3" Text="{Binding ET}" Style="{StaticResource FieldValueTextStyle}" Margin="0,0,12,0" />
                            <TextBlock Grid.Column="4" Text="{Binding NOF}" Style="{StaticResource FieldValueTextStyle}" Margin="0,0,12,0" />
                            <TextBlock Grid.Column="5" Text="{Binding Task}" Style="{StaticResource FieldValueTextStyle}" />

                            <Border Grid.Column="1" BorderBrush="#22000000" BorderThickness="0,0,1,0" Margin="0,0,12,0" VerticalAlignment="Stretch" SnapsToDevicePixels="True" />
                            <Border Grid.Column="2" BorderBrush="#22000000" BorderThickness="0,0,1,0" Margin="0,0,12,0" VerticalAlignment="Stretch" SnapsToDevicePixels="True" />
                            <Border Grid.Column="3" BorderBrush="#22000000" BorderThickness="0,0,1,0" Margin="0,0,12,0" VerticalAlignment="Stretch" SnapsToDevicePixels="True" />
                            <Border Grid.Column="4" BorderBrush="#22000000" BorderThickness="0,0,1,0" Margin="0,0,12,0" VerticalAlignment="Stretch" SnapsToDevicePixels="True" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Border>
</Window>
